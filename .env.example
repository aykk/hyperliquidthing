# Hyperliquid API Configuration (backend / Python bot)
# Copy this file to .env and fill in real values. Never commit the real .env.

# Network: false = testnet (recommended while iterating), true = mainnet.
IS_MAINNET=false

# Funded account that holds capital and whose positions/state are tracked.
MAIN_ACCOUNT_ADDRESS="0x0000000000000000000000000000000000000000"

# Signer. Either an approved AGENT wallet's key, or (on testnet) the master
# wallet's own key for direct trading. AGENT_ADDRESS is the signer's address.
AGENT_ADDRESS="0x0000000000000000000000000000000000000000"
WALLET_PRIVATE_KEY="YOUR_PRIVATE_KEY_HERE"

# --- Risk / sizing (tune per strategy budget) ------------------------------
# Simulated paper account size (USD).
STARTING_EQUITY=250
# Notional per trade in USD (protocol minimum is 10).
ORDER_NOTIONAL_USD=25
# Max simultaneous open positions.
MAX_CONCURRENT_POSITIONS=5
# API write budget/hour (a trade = entry+SL+TP ≈ 3 writes).
MAX_ORDERS_PER_HOUR=30
# Label trades with the strategy/version that produced them, so multiple
# experiments can be compared in the journal/dashboard. Change per run.
# Convention: obi_v1 = maker, obi_v2 = taker, obi_v3 = hybrid + edge/cost filters,
# obi_v4 = v3 gates + "let winners run" (no flip-cut, trailing stop).
STRATEGY_NAME=obi_v1
# Entry execution model:
#   maker  = rest a post-only (Alo) order at the passive side. Rare fills (~5%),
#            no taker fee, prone to adverse selection.
#   taker  = cross the spread with a marketable IOC. Near-100% fills so the
#            signal is actually tested, pays the spread + taker fee per entry.
#   hybrid = rest as a maker, then cross as a taker if unfilled after the chase.
ENTRY_MODE=maker
# Taker entries: cap how far past the touch we'll pay/sell (0.001 = 0.1%).
MAX_TAKER_SLIPPAGE_PCT=0.001
# Hybrid only: seconds the post-only rests before crossing as a taker.
HYBRID_CHASE_SECONDS=5

# --- obi_v3 signal / risk tuning (defaults reproduce obi_v1/obi_v2) --------
# Entry thresholds; wider = fewer, higher-conviction trades.
LONG_THRESHOLD=0.70
SHORT_THRESHOLD=0.30
# Signal-flip exit hysteresis + minimum hold (seconds). Defaults 0.50/0.50/0 =
# original symmetric flip with no hold. obi_v3 uses e.g. 0.45 / 0.55 / 10.
EXIT_LONG_BELOW=0.50
EXIT_SHORT_ABOVE=0.50
MIN_HOLD_SECONDS=0
# Skip entries when top-of-book spread (percent) exceeds this. blank/inf = off.
# MAX_ENTRY_SPREAD_PCT=0.05
# Aggressor-flow confirmation + liquidity floor (uses the trades stream; needs
# REAL flow, so enable on mainnet only). REQUIRE_FLOW_CONFIRM gates direction;
# MIN_FLOW_NOTIONAL_USD skips dead/illiquid windows.
REQUIRE_FLOW_CONFIRM=false
FLOW_WINDOW_SECONDS=30
FLOW_CONFIRM_RATIO=0.55
MIN_FLOW_NOTIONAL_USD=0

# --- obi_v4 "let winners run" (defaults reproduce obi_v3) ------------------
# Disable the order-book signal-flip exit so a position is managed only by its
# SL / TP / trailing stop (lets a winner run instead of cutting on noise).
DISABLE_FLIP_EXIT=false
# Hard protective bracket, now env-tunable (were fixed 1.5%/1.5% before).
STOP_LOSS_PCT=0.015
TAKE_PROFIT_PCT=0.015
# Trailing stop: arm after price runs TRAIL_ACTIVATE_PCT past entry, then ride
# TRAIL_PCT behind the best favorable price. TRAIL_PCT=0 keeps it OFF.
TRAIL_ACTIVATE_PCT=0.0
TRAIL_PCT=0.0

# --- Live runner (bot/live.py) ---------------------------------------------
# Optional fixed trade universe (comma-separated). On testnet the volume
# screener finds nothing, so live.py defaults to BTC,ETH. Uncomment to override.
# COINS=BTC,ETH
# Set true to wire up live.py and LOG intended orders without sending any.
LIVE_DRY_RUN=false
